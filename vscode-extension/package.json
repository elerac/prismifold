{
  "name": "plenoview-vscode",
  "displayName": "Plenoview",
  "description": "OpenEXR viewer for computational imaging, rendering, and vision workflows.",
  "icon": "icon.png",
  "version": "0.2.0",
  "publisher": "elerac",
  "license": "MIT",
  "homepage": "https://elerac.github.io/plenoview/app/",
  "bugs": {
    "url": "https://github.com/elerac/plenoview/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/elerac/plenoview.git",
    "directory": "vscode-extension"
  },
  "keywords": [
    "openexr",
    "exr",
    "hdr",
    "image viewer",
    "visualization",
    "rendering",
    "computational imaging"
  ],
  "galleryBanner": {
    "color": "#0b1020",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:plenoview.exrViewer",
    "onCommand:plenoview.openFile",
    "onCommand:plenoview.openFolder"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "plenoview.exrViewer",
        "displayName": "Plenoview OpenEXR Viewer",
        "selector": [
          {
            "filenamePattern": "*.exr"
          },
          {
            "filenamePattern": "*.EXR"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "plenoview.openFile",
        "title": "Plenoview: Open EXR File"
      },
      {
        "command": "plenoview.openFolder",
        "title": "Plenoview: Open EXR Folder"
      },
      {
        "command": "plenoview.exportImage",
        "title": "Plenoview: Export Image"
      },
      {
        "command": "plenoview.exportScreenshot",
        "title": "Plenoview: Export Screenshot"
      },
      {
        "command": "plenoview.exportBatch",
        "title": "Plenoview: Export Batch"
      },
      {
        "command": "plenoview.exportColormap",
        "title": "Plenoview: Export Colormap"
      },
      {
        "command": "plenoview.reloadAll",
        "title": "Plenoview: Reload All"
      },
      {
        "command": "plenoview.closeAll",
        "title": "Plenoview: Close All"
      },
      {
        "command": "plenoview.showMetadata",
        "title": "Plenoview: Show Metadata"
      },
      {
        "command": "plenoview.openSettings",
        "title": "Plenoview: Open Settings"
      },
      {
        "command": "plenoview.viewImage",
        "title": "Plenoview: Image Viewer"
      },
      {
        "command": "plenoview.viewPanorama",
        "title": "Plenoview: Panorama Viewer"
      },
      {
        "command": "plenoview.view3d",
        "title": "Plenoview: 3D Viewer"
      },
      {
        "command": "plenoview.toggleRulers",
        "title": "Plenoview: Toggle Rulers"
      },
      {
        "command": "plenoview.splitVertical",
        "title": "Plenoview: Split Viewer Vertically"
      },
      {
        "command": "plenoview.splitHorizontal",
        "title": "Plenoview: Split Viewer Horizontally"
      },
      {
        "command": "plenoview.resetPanes",
        "title": "Plenoview: Reset Viewer Panes"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "plenoview.openFile",
          "when": "resourceExtname == .exr || resourceExtname == .EXR",
          "group": "navigation@20"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test": "npm run compile && node ./out/test/runTest.js",
    "package": "npm run compile && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.120.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "mocha": "^11.7.6",
    "typescript": "^5.7.2"
  }
}
