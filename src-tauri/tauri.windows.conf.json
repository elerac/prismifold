{
  "app": {
    "windows": [
      {
        "title": "Plenoview",
        "url": "app/index.html",
        "width": 1440,
        "height": 960,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "resources": {
      "target/thumbnail-provider/plenoview_exr_thumbnail.dll": "plenoview_exr_thumbnail.dll"
    },
    "windows": {
      "wix": {
        "fragmentPaths": ["windows/exr-thumbnail-provider.wxs"],
        "componentGroupRefs": ["ExrThumbnailProviderComponents"]
      },
      "nsis": {
        "installerHooks": "windows/exr-thumbnail-provider.nsh"
      }
    }
  }
}
